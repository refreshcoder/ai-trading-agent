# 大模型 API 配置
LLM_API_KEY=your_api_key_here
LLM_API_BASE_URL=https://api.openai.com/v1

# 行情数据源
DATA_PROVIDER=offline

# 股票池（自选列表；支持 600519,000001 或 600519.SH 形式）
SYMBOLS=600519,000001

# 轮询与刷新策略
SPOT_POLL_INTERVAL_SEC=30
KLINE_REFRESH_INTERVAL_SEC=300
STRICT_TRADING_SESSIONS=true

# AkShare 若需要鉴权（多数接口不需要，可留空）
AKSHARE_TOKEN=

# 模拟盘初始资金
INITIAL_CASH=500000.0

# main.py 演示模式：循环次数（0 表示无限）
MAX_LOOPS=3

# 日志级别
LOG_LEVEL=INFO
